{
  "name": "agentic-sdlc-mcp",
  "version": "1.8.0",
  "mcpName": "io.github.SakuraCianna/agentic-sdlc-mcp",
  "description": "An MCP Server acting as an Agentic SDLC Control Plane — helps AI coding agents plan, create, test, review, secure, and release software following GitHub Agentic AI best practices.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentic-sdlc-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "server.json",
    ".env.example"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "check:line-endings": "node scripts/check-line-endings.mjs",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/__tests__/config.integration.test.ts src/__tests__/mcp-protocol.integration.test.ts src/__tests__/mcp-tool-runtime.integration.test.ts src/__tests__/mcp-http-runtime.integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "smoke": "node dist/index.js --smoke",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test && npm run smoke"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github",
    "sdlc",
    "agentic",
    "ai",
    "devops",
    "claude"
  ],
  "author": "SakuraCianna",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SakuraCianna/agentic-sdlc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SakuraCianna/agentic-sdlc-mcp/issues"
  },
  "homepage": "https://github.com/SakuraCianna/agentic-sdlc-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
