# GitHub Personal Access Token or GitHub App token
# Required: needs repo, read:org, security_events scopes for full functionality
GITHUB_TOKEN=ghp_your_token_here

# Default GitHub owner (organization or user)
# Optional — can be overridden per-tool call
GITHUB_OWNER=your-org-or-username

# Default GitHub repo name
# Optional — can be overridden per-tool call
GITHUB_REPO=your-repo-name

# Default branch name (defaults to "main" if not set)
SDLC_DEFAULT_BRANCH=main

# Transport mode: "stdio" (default) or "http"
TRANSPORT=stdio

# HTTP port (only used when TRANSPORT=http)
PORT=3000
